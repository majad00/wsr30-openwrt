include $(TOPDIR)/rules.mk
include $(INCLUDE_DIR)/kernel.mk

# Note: build_fix.mk is optional, only include if you actually have it
# include $(src)/build_fix.mk 

PKG_NAME:=rtl8822bu
PKG_RELEASE:=1

include $(INCLUDE_DIR)/package.mk

# ------------------------------------------------------------------------
#  Flags: Essential for defining the Hardware and Interface
# ------------------------------------------------------------------------
EXTRA_CFLAGS += -I$(src)/include
EXTRA_CFLAGS += -I$(src)/core
EXTRA_CFLAGS += -I$(src)/core/crypto
EXTRA_CFLAGS += -I$(src)/platform
EXTRA_CFLAGS += -I$(src)/hal/phydm
EXTRA_CFLAGS += -I$(src)/hal/halmac
EXTRA_CFLAGS += -I$(src)/os_dep
EXTRA_CFLAGS += -I$(src)/os_dep/linux
EXTRA_CFLAGS += -I$(src)/hal/btc
EXTRA_CFLAGS += -I$(src)/os_dep/include
EXTRA_CFLAGS += -I$(src)/hal/halmac/halmac_88xx
EXTRA_CFLAGS += -I$(src)/hal/rtl8822b

EXTRA_CFLAGS += -DCONFIG_USB_HCI
EXTRA_CFLAGS += -DCONFIG_RTL8822B
EXTRA_CFLAGS += -DCONFIG_HALMAC
EXTRA_CFLAGS += -DCONFIG_PHYDM

# --- Production Flags ---
EXTRA_CFLAGS += -DCONFIG_RTL8822B -DCONFIG_USB_HCI -DPLATFORM_LINUX
EXTRA_CFLAGS += -DCONFIG_HALMAC -DCONFIG_HALMAC_IF_USB
EXTRA_CFLAGS += -DHALMAC_8822B_SUPPORT -DHAL_8822B_SUPPORT
EXTRA_CFLAGS += -DCONFIG_IOCTL_CFG80211 -DCONFIG_80211W
EXTRA_CFLAGS += -DCONFIG_RTW_CFG80211_AS_INTFS -D__KERNEL__ -w

# --- Enabled to satisfy MODPOST Undefined Symbols ---
EXTRA_CFLAGS += -DCONFIG_BT_COEXIST -DCONFIG_ANTENNA_DIVERSITY
EXTRA_CFLAGS += -DCONFIG_BEAMFORMING
EXTRA_CFLAGS += -DCONFIG_MP_INCLUDED
EXTRA_CFLAGS += -UCONFIG_RTW_SW_LED
EXTRA_CFLAGS += -DCONFIG_RTL8822B
EXTRA_CFLAGS += -DCONFIG_USB_HCI
EXTRA_CFLAGS += -DCONFIG_IOCTL_CFG80211 -DCONFIG_CFG80211_FORCE_COMPATIBLE_2_6_37_UNDER
EXTRA_CFLAGS += -DCONFIG_RTW_ADAPTIVITY_EN -DCONFIG_RTW_ADAPTIVITY_MODE=0
EXTRA_CFLAGS += -DCONFIG_BT_COEXIST



define KernelPackage/rtl8822bu
  SUBMENU:=Wireless Drivers
  TITLE:=Realtek 8822BU (USB-only)
  DEPENDS:=+kmod-usb-core +kmod-cfg80211 +kmod-nls-base
  FILES:=$(PKG_BUILD_DIR)/rtl8822bu.ko
  AUTOLOAD:=$(call AutoProbe,rtl8822bu)
endef

define Build/Prepare
	mkdir -p $(PKG_BUILD_DIR)
	cp -r ./* $(PKG_BUILD_DIR)/
endef

# 1. Start with the main Core and HAL files
rtl8822bu-y := \
	core/rtw_ap.o core/rtw_br_ext.o core/rtw_btcoex.o core/rtw_btcoex_wifionly.o \
	core/rtw_chplan.o core/rtw_cmd.o core/rtw_debug.o core/rtw_eeprom.o \
	core/rtw_efuse.o core/rtw_ieee80211.o core/rtw_io.o \
	core/rtw_ioctl_query.o core/rtw_ioctl_set.o core/rtw_mi.o core/rtw_mlme.o \
	core/rtw_mlme_ext.o core/rtw_odm.o core/rtw_pwrctrl.o core/rtw_recv.o \
	core/rtw_rf.o core/rtw_security.o core/rtw_sreset.o core/rtw_sta_mgt.o \
	core/rtw_swcrypto.o core/rtw_vht.o core/rtw_wlan_util.o core/rtw_xmit.o \
	core/rtw_p2p.o core/rtw_beamforming.o core/rtw_rm.o core/rtw_roch.o \
	core/rtw_mp.o core/rtw_bt_mp.o \
	core/crypto/ccmp.o core/crypto/gcmp.o core/crypto/aes-ccm.o core/crypto/aes-gcm.o \
	core/crypto/aes-internal.o core/crypto/aes-internal-enc.o core/crypto/aes-siv.o \
	core/crypto/aes-ctr.o core/crypto/aes-omac1.o core/crypto/rtw_crypto_wrap.o \
	core/crypto/sha256.o core/crypto/sha256-internal.o core/crypto/sha256-prf.o \
	os_dep/osdep_service.o os_dep/linux/os_intfs.o os_dep/linux/usb_intf.o \
	os_dep/linux/usb_ops_linux.o os_dep/linux/ioctl_linux.o os_dep/linux/ioctl_cfg80211.o \
	os_dep/linux/xmit_linux.o os_dep/linux/mlme_linux.o os_dep/linux/recv_linux.o \
	os_dep/linux/rtw_cfgvendor.o os_dep/linux/ioctl_mp.o os_dep/linux/wifi_regd.o \
	os_dep/linux/rtw_android.o os_dep/linux/rtw_proc.o \
	hal/HalPwrSeqCmd.o hal/hal_com.o hal/hal_com_phycfg.o hal/hal_dm.o \
	hal/hal_halmac.o hal/hal_intf.o hal/hal_phy.o hal/hal_btcoex.o \
	hal/hal_btcoex_wifionly.o hal/hal_mp.o hal/hal_mcc.o hal/led/hal_led.o \
	hal/rtl8822b/rtl8822b_mac.o hal/phydm/phydm_math_lib.o \
	hal/rtl8822b/rtl8822b_phy.o hal/rtl8822b/rtl8822b_halinit.o \
	hal/rtl8822b/usb/rtl8822bu_halinit.o hal/rtl8822b/usb/rtl8822bu_ops.o \
	hal/rtl8822b/usb/rtl8822bu_halmac.o hal/rtl8822b/rtl8822b_cmd.o \
	hal/rtl8822b/hal8822b_fw.o hal/phydm/phydm_lna_sat.o \
	hal/phydm/phydm.o hal/phydm/phydm_api.o hal/phydm/phydm_debug.o \
	hal/phydm/phydm_dig.o hal/phydm/phydm_hwconfig.o hal/phydm/phydm_interface.o \
	hal/phydm/phydm_rainfo.o hal/phydm/phydm_rssi_monitor.o \
	hal/phydm/phydm_cfotracking.o hal/phydm/phydm_adaptivity.o \
	hal/phydm/phydm_antdiv.o hal/phydm/phydm_soml.o hal/phydm/phydm_cck_pd.o \
	hal/phydm/rtl8822b/phydm_rtl8822b.o hal/phydm/rtl8822b/phydm_hal_api8822b.o \
	hal/phydm/rtl8822b/halhwimg8822b_bb.o hal/phydm/rtl8822b/halhwimg8822b_mac.o \
	hal/phydm/halrf/halrf.o hal/phydm/halrf/rtl8822b/halrf_8822b.o \
	hal/phydm/halrf/halrf_stubs.o hal/phydm/halrf/halrf_powertracking.o \
	hal/phydm/halrf/halrf_kfree.o hal/phydm/halrf/halrf_debug.o \
	hal/phydm/halrf/halrf_powertracking_ap.o hal/phydm/phydm_pow_train.o\
	hal/phydm/halrf/rtl8822b/halrf_iqk_8822b.o hal/phydm/halrf/rtl8822b/halhwimg8822b_rf.o \
	hal/phydm/txbf/haltxbf8822b.o hal/phydm/txbf/phydm_hal_txbf_api.o \
	hal/halmac/halmac_api.o hal/halmac/halmac_dbg.o hal/phydm/phydm_dfs.o \
	hal/halmac/halmac_88xx/halmac_init_88xx.o hal/halmac/halmac_88xx/halmac_usb_88xx.o \
	hal/halmac/halmac_88xx/halmac_cfg_wmac_88xx.o hal/halmac/halmac_88xx/halmac_common_88xx.o \
	hal/halmac/halmac_88xx/halmac_efuse_88xx.o hal/halmac/halmac_88xx/halmac_flash_88xx.o \
	hal/halmac/halmac_88xx/halmac_fw_88xx.o hal/halmac/halmac_88xx/halmac_bb_rf_88xx.o \
	hal/halmac/halmac_88xx/halmac_gpio_88xx.o hal/halmac/halmac_88xx/halmac_mimo_88xx.o \
	hal/halmac/halmac_88xx/halmac_8822b/halmac_init_8822b.o hal/phydm/phydm_ccx.o \
	hal/halmac/halmac_88xx/halmac_8822b/halmac_usb_8822b.o \
	hal/halmac/halmac_88xx/halmac_8822b/halmac_cfg_wmac_8822b.o \
	hal/halmac/halmac_88xx/halmac_8822b/halmac_common_8822b.o \
	hal/halmac/halmac_88xx/halmac_8822b/halmac_phy_8822b.o \
	hal/halmac/halmac_88xx/halmac_8822b/halmac_gpio_8822b.o hal/phydm/txbf/phydm_hal_txbf_api.o \
	hal/halmac/halmac_88xx/halmac_8822b/halmac_pwr_seq_8822b.o hal/phydm/phydm_rssi_monitor.o \
	hal/btc/halbtc8822b1ant.o hal/btc/halbtc8822b2ant.o hal/btc/halbtc8822bwifionly.o \
	hal/efuse/rtl8822b/HalEfuseMask8822B_USB.o \
	hal/phydm/phydm_adc_sampling.o hal/phydm/phydm_noisemonitor.o hal/phydm/txbf/phydm_hal_txbf_api.o 
	
   
	
# This connects the rtl8822bu-y list to the rtl8822bu.ko module
rtl8822bu-objs := $(rtl8822bu-y)
obj-m += rtl8822bu.o

define Build/Compile
	$(MAKE) -C $(LINUX_DIR) \
		$(KERNEL_MAKE_FLAGS) \
		M="$(PKG_BUILD_DIR)" \
		EXTRA_CFLAGS="$(EXTRA_CFLAGS)" \
		modules
endef

$(eval $(call KernelPackage,rtl8822bu))