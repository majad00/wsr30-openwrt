obj-$(CONFIG_RTL8822BU) += rtl8822bu.o

# Simplify to use relative paths which are more robust in OpenWrt
EXTRA_CFLAGS += -I$(src)/include
EXTRA_CFLAGS += -I$(src)/core
EXTRA_CFLAGS += -I$(src)/platform
EXTRA_CFLAGS += -I$(src)/hal/phydm
EXTRA_CFLAGS += -I$(src)/hal/halmac
EXTRA_CFLAGS += -I$(src)/os_dep/include

# Keep your existing flags
EXTRA_CFLAGS += -Usint
EXTRA_CFLAGS += -DPLATFORM_LINUX
ccflags-y += -w -Wno-error -Dpr_debug=printk -DSIZE_T=size_t

# Define the root of your driver source
USER_MODULE_NAME := rtl8822bu

#
# Core Files
rtl8822bu-y := core/rtw_cmd.o core/rtw_security.o core/rtw_debug.o \
               core/rtw_io.o core/rtw_xmit.o core/rtw_recv.o \
               core/rtw_pwrctrl.o core/rtw_mlme.o core/rtw_ap.o \
               core/rtw_sta_mgt.o core/rtw_eeprom.o core/efuse/rtw_efuse.o \
               core/rtw_br_ext.o core/rtw_ieee80211.o core/rtw_wlan_util.o

# OS Dependent Files (USB)
rtl8822bu-y += os_dep/linux/os_intfs.o \
               os_dep/osdep_service.o \
               os_dep/linux/usb_intf.o \
               os_dep/linux/usb_ops_linux.o \
               os_dep/linux/rtw_android.o \
               os_dep/linux/ioctl_cfg80211.o
			   
# HAL and PHYDM (The brain of the driver)
# HAL and PHYDM
rtl8822bu-y += hal/hal_intf.o \
               hal/hal_com.o \
               hal/hal_com_phycfg.o \
               hal/hal_halmac.o \
               hal/hal_dm.o \
               hal/rtl8822b/rtl8822b_halinit.o \
               hal/rtl8822b/rtl8822b_ops.o \
               hal/rtl8822b/rtl8822b_phy.o \
               hal/rtl8822b/usb/rtl8822bu_ops.o \
               hal/rtl8822b/usb/rtl8822bu_halinit.o

# Include the HALMAC and PHYDM sub-logic (Simplest way to include many files)
# In a real kernel build, you'd list every single file here. 
# For now, let's ensure the core compiles.

